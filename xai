rundown_methods = results_df[[
    "vanilla_cos", "integrated_gradients_cos", "smoothgrad_cos", "lime_cos", "vanilla_gradients_top3", "integrated_gradients_top3", "smoothgrad_top3", "lime_top3"
]].mean()
print(rundown_methods)